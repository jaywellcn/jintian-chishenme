<!-- pages/settings/settings.wxml -->
<view class="page-container">
  
  <view class="settings-section">
    <text class="section-title">📍 归属地</text>
    <view class="setting-item" bindtap="changeCity">
      <text class="setting-label">所在城市</text>
      <view class="setting-value-row">
        <text class="setting-value">{{profile.location_city || '未设置'}}</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <text class="section-title">👅 口味偏好</text>
    <view class="taste-cloud">
      <view class="taste-chip {{utils.isSelected(profile.taste_tags, item.value) ? 'selected' : ''}}" 
            wx:for="{{allTasteTags}}" 
            wx:key="value"
            bindtap="toggleTaste"
            data-value="{{item.value}}">
        <text>{{item.emoji}} {{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <text class="section-title">🚫 忌口</text>
    <view class="taboo-cloud">
      <view class="taboo-chip {{utils.isSelected(profile.taboos, item.value) ? 'selected' : ''}}" 
            wx:for="{{allTabooOptions}}" 
            wx:key="value"
            bindtap="toggleTaboo"
            data-value="{{item.value}}">
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <text class="section-title">🍽 场景偏好</text>
    <view class="scene-options">
      <view class="scene-option {{profile.scene_preference === item.value ? 'selected' : ''}}" 
            wx:for="{{allSceneOptions}}" 
            wx:key="value"
            bindtap="selectScene"
            data-value="{{item.value}}">
        <text class="scene-option-emoji">{{item.emoji}}</text>
        <text class="scene-option-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <text class="section-title">ℹ️ 关于</text>
    <view class="about-card">
      <text class="about-name">今天吃什么</text>
      <text class="about-version">版本 1.0.0</text>
      <text class="about-desc">基于二十四节气的时令饮食推荐</text>
      <text class="about-desc">顺时而食，应季而养</text>
    </view>
  </view>

  <view class="save-area">
    <button class="btn-save" bindtap="savePreferences">保存偏好</button>
  </view>
</view>
