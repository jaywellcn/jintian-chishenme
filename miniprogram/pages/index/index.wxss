/* index page styles */

.page-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* season banner */
.season-banner {
  padding: 40rpx 30rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
  color: #fff;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.banner-emoji {
  font-size: 72rpx;
  margin-right: 20rpx;
}

.banner-info {
  display: flex;
  flex-direction: column;
}

.banner-term-name {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.banner-date {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.banner-tip {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  font-style: italic;
}

/* hint bar */
.hint-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 30rpx;
  padding: 18rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #4CAF50;
  flex: 1;
}

/* section label */
.section-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  margin-top: 30rpx;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
}

.label-date {
  font-size: 24rpx;
  color: #BDBDBD;
}

/* recipe card */
.recipe-main-card {
  margin: 0 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.recipe-main-card:active {
  transform: scale(0.98);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-category {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.card-category.cat-takeout {
  background: #FFF3E0;
  color: #E65100;
}

.card-category.cat-cook {
  background: #E8F5E9;
  color: #2E7D32;
}

.card-category.cat-quick {
  background: #E3F2FD;
  color: #1565C0;
}

.card-difficulty {
  font-size: 22rpx;
}

.card-dish-name {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.card-reason {
  display: flex;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.reason-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.reason-text {
  font-size: 26rpx;
  color: #757575;
  line-height: 1.5;
}

.card-ingredients {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: 20rpx;
}

.ingredients-label {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.ingredient-tag {
  font-size: 24rpx;
  color: #388E3C;
  background: #C8E6C9;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.card-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #757575;
}

/* action buttons */
.action-buttons {
  display: flex;
  margin: 24rpx 30rpx;
  gap: 20rpx;
}

.btn-refresh, .btn-favorite {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.btn-refresh:active, .btn-favorite:active {
  transform: scale(0.96);
}

.btn-favorite.favorited {
  background: #FFF0F0;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* loading / error */
.loading-card {
  margin: 40rpx 30rpx;
  padding: 80rpx;
  text-align: center;
  background: #fff;
  border-radius: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #757575;
}

.error-card {
  margin: 40rpx 30rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  background: #fff;
  border-radius: 24rpx;
}

.error-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #757575;
  display: block;
  margin-bottom: 30rpx;
}

.btn-retry {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
  border: none;
}

/* seasonal ingredients */
.seasonal-section {
  margin: 0 30rpx;
}

.ingredients-cloud {
  display: flex;
  flex-wrap: wrap;
  padding: 0 0 16rpx;
}

.ingredient-chip {
  font-size: 26rpx;
  padding: 10rpx 22rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-right: 14rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}

.seasonal-tip {
  display: block;
  font-size: 24rpx;
  color: #BDBDBD;
  margin-top: 10rpx;
}

.bottom-safe {
  height: 20rpx;
}
