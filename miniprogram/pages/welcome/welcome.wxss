/* pages/welcome/welcome.wxss */
.welcome-container {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}

.welcome-slide {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.welcome-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.welcome-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 12rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.welcome-features {
  width: 100%;
  margin-bottom: 60rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.feature-emoji {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.feature-text {
  font-size: 30rpx;
  color: #555;
}

.btn-start, .btn-next, .btn-finish {
  width: 100%;
  padding: 26rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 20rpx;
}

.btn-start {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
}

.btn-next {
  background: #4CAF50;
  color: #fff;
}

.btn-next[disabled] {
  background: #BDBDBD;
}

.btn-finish {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #fff;
}

.skip-link {
  font-size: 26rpx;
  color: #BDBDBD;
  margin-top: 24rpx;
}

/* step title */
.step-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* city picker */
.location-status {
  padding: 40rpx;
  color: #999;
}

.city-display {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  width: 100%;
  margin-bottom: 20rpx;
}

.city-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.city-name {
  font-size: 36rpx;
  font-weight: 600;
  flex: 1;
}

.city-change {
  font-size: 26rpx;
  color: #4CAF50;
}

.city-picker {
  width: 100%;
}

.city-input {
  width: 100%;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.city-list {
  max-height: 300rpx;
  margin-top: 10rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.city-option {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

/* taste grid */
.taste-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
  margin-bottom: 30rpx;
}

.taste-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  width: calc(25% - 12rpx);
  box-sizing: border-box;
  transition: all 0.2s;
}

.taste-item.selected {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.taste-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.taste-label {
  font-size: 24rpx;
  color: #555;
}

/* taboo */
.taboo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  width: 100%;
  margin-bottom: 30rpx;
}

.taboo-item {
  padding: 16rpx 28rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 28rpx;
  transition: all 0.2s;
}

.taboo-item.selected {
  background: #FFEBEE;
  border: 2rpx solid #F44336;
  color: #F44336;
}

/* scene */
.scene-list {
  width: 100%;
  margin-bottom: 30rpx;
}

.scene-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.scene-item.selected {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.scene-emoji {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.scene-info {
  display: flex;
  flex-direction: column;
}

.scene-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.scene-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* progress */
.progress-dots {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E0E0E0;
  transition: all 0.3s;
}

.dot.active {
  background: #4CAF50;
  width: 24rpx;
  border-radius: 6rpx;
}
