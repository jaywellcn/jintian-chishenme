/* pages/detail/detail.wxss */
.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

.detail-header {
  padding: 40rpx 30rpx 60rpx;
  border-radius: 0 0 40rpx 40rpx;
  color: #fff;
}

.dish-category-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.dish-name {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

.dish-meta {
  display: flex;
  gap: 20rpx;
}

.meta-badge {
  font-size: 24rpx;
  opacity: 0.9;
}

/* reason */
.reason-card {
  margin-top: -20rpx;
}

.reason-header {
  margin-bottom: 12rpx;
}

.reason-title {
  font-size: 28rpx;
  font-weight: 600;
}

.reason-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

.reason-tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-green {
  background: #E8F5E9;
  color: #2E7D32;
}

/* ingredients */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
}

.ingredient-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.ing-dot {
  font-size: 24rpx;
  color: #4CAF50;
  margin-right: 12rpx;
}

.ing-name {
  font-size: 28rpx;
  flex: 1;
}

.ing-seasonal {
  font-size: 20rpx;
  background: #E8F5E9;
  color: #388E3C;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

/* steps */
.step-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.step-number {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.step-text {
  font-size: 28rpx;
  line-height: 1.6;
  flex: 1;
  padding-top: 4rpx;
}

/* bottom bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.bar-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  background: #F5F5F5;
}

.bar-btn.favorited {
  background: #FFF0F0;
  color: #F44336;
}

.share-btn {
  background: #4CAF50;
  color: #fff;
}
