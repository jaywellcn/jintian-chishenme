/* app.wxss - global styles */
page {
  --primary: #4CAF50;
  --primary-dark: #388E3C;
  --primary-light: #C8E6C9;
  --accent: #FF9800;
  --accent-light: #FFE0B2;
  --danger: #F44336;
  --text-primary: #212121;
  --text-secondary: #757575;
  --text-hint: #BDBDBD;
  --bg: #F5F5F5;
  --bg-white: #FFFFFF;
  --border: #E0E0E0;
  --shadow: 0 2px 12px rgba(0,0,0,0.08);
  --radius: 16rpx;
  --radius-lg: 24rpx;
  
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg);
  line-height: 1.6;
}

/* buttons */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: var(--radius);
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius);
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

/* cards */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: var(--shadow);
}

/* tags */
.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.tag-green {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.tag-orange {
  background: var(--accent-light);
  color: #E65100;
}

.tag-gray {
  background: #EEEEEE;
  color: var(--text-secondary);
}

/* flex layout */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* text */
.text-primary {
  color: var(--primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

.text-center {
  text-align: center;
}

/* spacing */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* hide scrollbar */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
